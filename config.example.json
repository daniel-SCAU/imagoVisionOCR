{
  "camera_source": 0,
  "camera_backend": "any",
  "camera_width": 1920,
  "camera_height": 1080,
  "camera_fps": 30,
  "camera_exposure": 2000,
  "use_xm2_sdk": false,
  "warmup_frames": 5,
  "trigger_mode": false,

  "use_genicam": false,
  "genicam_cti": "/path/to/producer.cti",

  "detection_model": "roboflow",
  "roboflow_api_key": "YOUR_API_KEY",
  "roboflow_project": "YOUR_PROJECT_ID",
  "roboflow_version": 1,
  "yolo_weights": "yolov8n.pt",
  "confidence_threshold": 0.5,

  "ocr_engine": "paddleocr",
  "ocr_lang": "en",
  "ocr_use_gpu": true,

  "validation_rules": "{\"lot_number\": \"LOT\\\\d{6}[A-Z]\", \"expiry\": \"\\\\d{4}-\\\\d{2}-\\\\d{2}\"}",

  "storage_path": "./archive",
  "image_format": "jpg",
  "jpeg_quality": 95,
  "nas_enabled": false,
  "nas_path": "//nas/ocr",
  "nas_username": "",

  "gstreamer_pipeline": ""
}
